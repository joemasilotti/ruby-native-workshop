<%#
  Locals: progress (BudgetSummary::CategoryProgress)
%>
<%= link_to new_expense_path(category_id: progress.category.id), class: "block border-b border-line py-[13px] last:border-b-0" do %>
  <div class="mb-2 flex items-center gap-2.5">
    <span class="grid h-[38px] w-[38px] shrink-0 place-items-center rounded-[11px] text-[19px]" style="background: color-mix(in srgb, <%= progress.color %> 16%, var(--color-surface))"><%= progress.emoji %></span>
    <span class="flex-1 text-[15px] font-semibold"><%= progress.name %></span>
    <span class="text-sm font-bold tabular-nums <%= "text-danger" if progress.over? %>">
      <%= money(progress.spent) %><span class="font-medium text-muted"> / <%= money(progress.budget) %></span>
    </span>
  </div>
  <%= render "shared/bar", percent: progress.percent, color: progress.color %>
<% end %>

<% content_for :title, "Open on your phone" %>

<div class="mx-auto w-[min(100%-2rem,400px)] pt-10 text-center">
  <div class="mb-[22px]">
    <span class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-brand text-[34px] font-extrabold text-white">¢</span>
    <h1 class="mt-3.5 text-2xl">Scan in the Ruby Native app</h1>
  </div>

  <div class="rounded-2xl border border-line bg-surface p-5 shadow-card">
    <div class="mx-auto w-[240px] max-w-full rounded-xl bg-white p-3 [&>svg]:h-auto [&>svg]:w-full">
      <%= raw @svg %>
    </div>

    <p class="mt-4 break-all font-mono text-sm text-muted"><%= @url %></p>
  </div>

  <% unless @in_codespace %>
    <p class="mt-4 text-left text-xs text-muted">
      Not running in a Codespace, so this encodes the current address. To scan from a phone, open this page via your machine's LAN IP (for example <span class="font-mono">http://192.168.x.x:3000/qr</span>) on the same Wi-Fi.
    </p>
  <% end %>
</div>
